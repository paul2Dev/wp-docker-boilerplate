MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root

WORDPRESS_PORT=8080
PHPMYADMIN_PORT=8081

# Schimba portul WORDPRESS_PORT/PHPMYADMIN_PORT doar daca ai deja alt proiect
# din acest boilerplate pornit simultan (conflict de port).

# Imagini Docker. Valorile de mai jos sunt tag-uri "rolling" (folosite doar
# pana la primul `make pin-versions`, care le rezolva la un digest exact si
# le suprascrie aici - versiunile raman apoi blocate pentru acest proiect,
# indiferent ce se publica ulterior pe Docker Hub). Ruleaza `make pin-versions`
# o singura data, imediat dupa clonare, INAINTE de primul `make up`.
WORDPRESS_IMAGE=wordpress:php8.3-apache
MYSQL_IMAGE=mysql:8.0
PHPMYADMIN_IMAGE=phpmyadmin:latest
WPCLI_IMAGE=wordpress:cli

THEME_SLUG=placeholder-theme

# Titlul site-ului (folosit la wp core install --title) si baza pentru
# username-ul admin generat automat de `make wp-install` (adm_user_<slug>).
WEBSITE_NAME="Placeholder Website"
ADMIN_EMAIL=admin@example.com

